# Base path of the CareerLinkAI API (FULLPLAN §19). Must include the /api/v1 prefix.
#
# The API is the Cloudflare Worker in ../backend, served locally by `wrangler dev`, which
# listens on port 8787 by default. (Before v1.3 this pointed at the retired Laravel API on
# port 8000.)
VITE_API_BASE_URL=http://localhost:8787/api/v1
