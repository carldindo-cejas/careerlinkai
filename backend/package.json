{
  "name": "careerlinkai-backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --config wrangler.test.toml",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:production": "wrangler deploy --env production",
    "type-check": "tsc --noEmit",
    "lint": "eslint src test",
    "format": "prettier --write \"{src,test}/**/*.ts\"",
    "format:check": "prettier --check \"{src,test}/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "gate:platform": "node scripts/platform-gates.mjs",
    "gate:bundle": "node scripts/platform-gates.mjs --bundle",
    "dev:ai": "wrangler dev",
    "db:migrate": "wrangler d1 migrations apply CareerLinkAI_Main --local",
    "db:migrate:staging": "wrangler d1 migrations apply CareerLinkAI_Staging --remote --env staging",
    "db:migrate:production": "wrangler d1 migrations apply CareerLinkAI_Main --remote --env production",
    "db:seed": "npm run db:seed:staff && npm run db:seed:catalog && npm run db:seed:ai-policy",
    "db:seed:staff": "wrangler d1 execute CareerLinkAI_Main --local --file=./seeds/0001_staff_accounts.sql",
    "db:seed:catalog": "wrangler d1 execute CareerLinkAI_Main --local --file=./seeds/0002_academic_catalog.sql",
    "db:seed:ai-policy": "wrangler d1 execute CareerLinkAI_Main --local --file=./seeds/0003_ai_policy.sql",
    "db:seed:catalog:staging": "wrangler d1 execute CareerLinkAI_Staging --remote --env staging -y --file=./seeds/0002_academic_catalog.sql",
    "db:seed:ai-policy:staging": "wrangler d1 execute CareerLinkAI_Staging --remote --env staging -y --file=./seeds/0003_ai_policy.sql"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.30",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.4",
    "@cloudflare/workers-types": "^5.20260713.1",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "prettier": "^3.9.5",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  }
}
